# ── Rust ──
/target/
**/*.rs.bk
Cargo.lock

# ── Node.js ──
node_modules/
.next/
out/
*.tsbuildinfo

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# ── 环境配置 ──
.env
.env.local
.env.*.local

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── 系统文件 ──
.DS_Store
Thumbs.db

# ── Docker ──
docker-compose.override.yml

# ── 日志 ──
*.log
logs/

