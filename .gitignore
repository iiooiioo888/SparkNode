node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.turbo/
.parcel-cache/
.eslintcache
.stylelintcache

# ── Python ──
