# ═══════════════════════════════════════════════════
#  灵犀节点 (SparkNode) 环境配置
#  复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════════

# ── 基础设施 ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sparknode
POSTGRES_USER=spark
POSTGRES_PASSWORD=spark_dev_password

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687

REDIS_HOST=localhost
REDIS_PORT=6379

# ── Rust 网关 ─────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3001
GATEWAY_WS_PORT=3002
GATEWAY_GRPC_PORT=3003

# JWT 密钥 (生产环境请更换)
JWT_SECRET=sparknode_dev_secret_change_in_production
JWT_EXPIRATION_HOURS=72

# 開發預設作者（對應 migrations/003_seed_dev_user.sql）
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# Qdrant（靈魂引擎向量記憶）
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=npc_memories

# ── Python LLM 服务 ──────────────────────────────
LLM_ROUTER_HOST=0.0.0.0
LLM_ROUTER_PORT=8001

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 本地模型 (vLLM / Ollama)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ── 嵌入模型 (用于 NPC 海马体记忆向量化) ────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── 前端 ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_WS_GATEWAY=ws://localhost:3002

# ── 日志级别 ─────────────────────────────────────
RUST_LOG=info,sp_gateway=debug,sp_narrative_engine=debug
PYTHON_LOG_LEVEL=DEBUG